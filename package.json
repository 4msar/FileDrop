{
  "name": "filedrop",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "vite frontend",
    "dev:worker": "wrangler dev --ip 0.0.0.0 --port 8787",
    "dev": "concurrently \"yarn dev:frontend\" \"yarn dev:worker\"",
    "build": "vite build frontend",
    "deploy": "yarn build && wrangler deploy"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "concurrently": "^8.0.0",
    "wrangler": "^3.0.0"
  }
}